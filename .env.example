PORT=8080
GIN_MODE=debug

# Logging (zap)
LOG_LEVEL=info
LOG_FORMAT=console

# LLM provider: groq | openai
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_JSON_MODE=true


# GitHub App / PAT for fetching PRs and posting review comments
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Optional: auto-post review summary as a PR comment
GITHUB_POST_COMMENTS=true

# Optional: post GitHub Check Run (or commit status fallback) on PR head
GITHUB_POST_CHECKS=true

# Redis (async webhook + background reviews) — REQUIRED for GitHub webhooks
# Completed jobs are retained for 24h so GET /api/v1/review/jobs/:id can return results.
# Webhooks always enqueue; duplicate deliveries for the same PR head SHA are deduplicated.
REDIS_ADDR=localhost:6379

# Static analysis tools (install separately; skipped if not in PATH)
GOSEC_PATH=gosec
SEMGREP_PATH=semgrep

# Review limits
MAX_CHUNK_BYTES=50000
MAX_REPO_FILES=20

# ---- Docker quick start ----
# 1. cp .env.example .env   (then add your real API keys)
# 2. docker compose up --build
# 3. curl http://localhost:8080/health
